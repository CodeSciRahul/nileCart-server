PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

MONGODB_URI=mongodb://127.0.0.1:27017/saavana
JWT_SECRET=your_super_secret_jwt_key_change_in_production

# Seller email OTP — Nodemailer (temporary; takes priority when configured)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="LightCollection <your-email@gmail.com>"

# Resend — seller email OTP fallback (https://resend.com)
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM_EMAIL=onboarding@resend.dev

# One-time admin setup (run: npm run seed:admin)
# ADMIN_EMAIL=admin@yourdomain.com
# ADMIN_PASSWORD=your_secure_password
# ADMIN_NAME=Platform Admin

# Firebase Admin — use ONE of these:
# FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json
FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}
